  assigned_at                               DateTime      @default(now()) @db.Timestamptz(6)
  profiles_user_roles_assigned_byToprofiles profiles?     @relation("user_roles_assigned_byToprofiles", fields: [assigned_by], references: [id])
  organizations                             organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  roles                                     roles         @relation(fields: [role_id], references: [id], onDelete: Cascade)
  profiles_user_roles_user_idToprofiles     profiles      @relation("user_roles_user_idToprofiles", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id, role_id])
}

model user_streaks {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String        @db.Uuid
  user_id            String        @db.Uuid
  streak_key         String
  current_streak     Int           @default(0)
  best_streak        Int           @default(0)
  last_activity_date DateTime?     @db.Date
  created_at         DateTime      @default(now()) @db.Timestamptz(6)
  updated_at         DateTime      @default(now()) @db.Timestamptz(6)
  organizations      organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles           profiles      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id, streak_key])
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime
  created_at DateTime @default(now()) @db.Timestamptz(6)
  id         String   @id
  updated_at DateTime @db.Timestamptz(6)

  @@index([identifier])
}

model wallet_transactions {
  id                                                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                                   String                    @db.Uuid
  user_id                                           String                    @db.Uuid
  transaction_type                                  String
  action_key                                        String
  points_delta                                      Int
  balance_after                                     Int
  company_id                                        String?                   @db.Uuid
  followup_id                                       String?                   @db.Uuid
  challenge_id                                      String?                   @db.Uuid
  reward_id                                         String?                   @db.Uuid
  source_record_id                                  String?                   @db.Uuid
  source_record_type                                String?
  idempotency_key                                   String
  metadata                                          Json                      @default("{}")
  created_by                                        String?                   @db.Uuid
  created_at                                        DateTime                  @default(now()) @db.Timestamptz(6)
  scoring_activity_logs                             scoring_activity_logs[]
  user_challenge_progress                           user_challenge_progress[]
  challenge_templates                               challenge_templates?      @relation(fields: [challenge_id], references: [id])
  companies                                         companies?                @relation(fields: [company_id], references: [id])
  profiles_wallet_transactions_created_byToprofiles profiles?                 @relation("wallet_transactions_created_byToprofiles", fields: [created_by], references: [id])
  followups                                         followups?                @relation(fields: [followup_id], references: [id])
  organizations                                     organizations             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  rewards_catalog                                   rewards_catalog?          @relation(fields: [reward_id], references: [id])
  profiles_wallet_transactions_user_idToprofiles    profiles                  @relation("wallet_transactions_user_idToprofiles", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, idempotency_key])
  @@index([organization_id, user_id, created_at(sort: Desc)])
}

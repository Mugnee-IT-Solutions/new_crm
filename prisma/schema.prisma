generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model access_passkeys {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  signup_request_id String          @db.Uuid
  email             String
  token_hash        String          @unique
  expires_at        DateTime        @db.Timestamptz(6)
  used_at           DateTime?       @db.Timestamptz(6)
  issued_by         String?         @db.Uuid
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  profiles          profiles?       @relation(fields: [issued_by], references: [id])
  signup_requests   signup_requests @relation(fields: [signup_request_id], references: [id], onDelete: Cascade)

  @@index([email, used_at, expires_at])
  @@index([issued_by])
  @@index([signup_request_id, created_at(sort: Desc)])
}

model accounts {
  id                       String    @id
  userId                   String    @db.Uuid
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  scope                    String?
  id_token                 String?
  access_token_expires_at  DateTime? @db.Timestamptz(6)
  created_at               DateTime  @default(now()) @db.Timestamptz(6)
  password                 String?
  refresh_token_expires_at DateTime? @db.Timestamptz(6)
  updated_at               DateTime  @db.Timestamptz(6)
  profiles                 profiles  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model activity_logs {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  actor_user_id   String?       @db.Uuid
  action          String
  entity_type     String?
  entity_id       String?       @db.Uuid
  metadata        Json          @default("{}")
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  profiles        profiles?     @relation(fields: [actor_user_id], references: [id])
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

model admin_audit_logs {
  id                                                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_user_id                                      String?        @db.Uuid
  target_user_id                                     String?        @db.Uuid
  organization_id                                    String?        @db.Uuid
  action                                             String
  entity_type                                        String
  entity_id                                          String?
  metadata                                           Json           @default("{}")
  created_at                                         DateTime       @default(now()) @db.Timestamptz(6)
  profiles_admin_audit_logs_actor_user_idToprofiles  profiles?      @relation("admin_audit_logs_actor_user_idToprofiles", fields: [actor_user_id], references: [id])
  organizations                                      organizations? @relation(fields: [organization_id], references: [id])
  profiles_admin_audit_logs_target_user_idToprofiles profiles?      @relation("admin_audit_logs_target_user_idToprofiles", fields: [target_user_id], references: [id])

  @@index([action, created_at(sort: Desc)])
  @@index([actor_user_id, created_at(sort: Desc)])
  @@index([organization_id, created_at(sort: Desc)])
  @@index([target_user_id, created_at(sort: Desc)])
}

model challenge_templates {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id         String                    @db.Uuid
  name                    String
  description             String?
  cadence                 String
  target_metric           String
  target_count            Int
  bonus_points            Int                       @default(0)
  is_active               Boolean                   @default(true)
  starts_at               DateTime?                 @db.Timestamptz(6)
  ends_at                 DateTime?                 @db.Timestamptz(6)
  config                  Json                      @default("{}")
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  organizations           organizations             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  scoring_activity_logs   scoring_activity_logs[]
  user_challenge_progress user_challenge_progress[]
  wallet_transactions     wallet_transactions[]
}

model companies {
  id                                               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                                  String                  @db.Uuid
  status                                           String                  @default("active")
  created_at                                       DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                                       DateTime                @default(now()) @db.Timestamptz(6)
  name                                             String
  industry_id                                      String?                 @db.Uuid
  category_id                                      String?                 @db.Uuid
  lead_source                                      String?
  priority                                         String                  @default("medium")
  assigned_user_id                                 String?                 @db.Uuid
  pipeline_stage_id                                String?                 @db.Uuid
  phone                                            String?
  whatsapp                                         String?
  email                                            String?
  website                                          String?
  address                                          String?
  city                                             String?
  country                                          String?
  success_rating                                   Int?
  lead_temperature                                 String                  @default("warm")
  estimated_value                                  Decimal?                @db.Decimal(14, 2)
  expected_closing_date                            DateTime?               @db.Date
  notes                                            String?
  created_by                                       String?                 @db.Uuid
  updated_by                                       String?                 @db.Uuid
  lead_score                                       Int                     @default(0)
  referred_by_user_id                              String?                 @db.Uuid
  phone_numbers                                    Json                    @default("[]")
  email_addresses                                  Json                    @default("[]")
  profiles_companies_assigned_user_idToprofiles    profiles?               @relation("companies_assigned_user_idToprofiles", fields: [assigned_user_id], references: [id])
  company_categories                               company_categories?     @relation(fields: [category_id], references: [id])
  profiles_companies_created_byToprofiles          profiles?               @relation("companies_created_byToprofiles", fields: [created_by], references: [id])
  industries                                       industries?             @relation(fields: [industry_id], references: [id])
  organizations                                    organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  pipeline_stages                                  pipeline_stages?        @relation(fields: [pipeline_stage_id], references: [id])
  profiles_companies_referred_by_user_idToprofiles profiles?               @relation("companies_referred_by_user_idToprofiles", fields: [referred_by_user_id], references: [id])
  profiles_companies_updated_byToprofiles          profiles?               @relation("companies_updated_byToprofiles", fields: [updated_by], references: [id])
  contact_persons                                  contact_persons[]
  documents                                        documents[]
  followups                                        followups[]
  help_requests                                    help_requests[]
  interactions                                     interactions[]
  scoring_activity_logs                            scoring_activity_logs[]
  wallet_transactions                              wallet_transactions[]

  @@index([assigned_user_id])
  @@index([organization_id])
  @@index([pipeline_stage_id])
}

model company_categories {
  id                                               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                                  String        @db.Uuid
  name                                             String
  code                                             String
  description                                      String?
  priority_level                                   Int           @default(3)
  status                                           String        @default("active")
  created_by                                       String?       @db.Uuid
  updated_by                                       String?       @db.Uuid
  created_at                                       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at                                       DateTime      @default(now()) @db.Timestamptz(6)
  companies                                        companies[]
  profiles_company_categories_created_byToprofiles profiles?     @relation("company_categories_created_byToprofiles", fields: [created_by], references: [id])
  organizations                                    organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles_company_categories_updated_byToprofiles profiles?     @relation("company_categories_updated_byToprofiles", fields: [updated_by], references: [id])

  @@unique([organization_id, code])
  @@index([organization_id])
}

model contact_persons {
  id                                            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                               String          @db.Uuid
  company_id                                    String          @db.Uuid
  name                                          String
  designation                                   String?
  department                                    String?
  mobile                                        String?
  whatsapp                                      String?
  email                                         String?
  linkedin                                      String?
  decision_role                                 String?
  relationship_level                            String?
  preferred_contact_method                      String?
  remarks                                       String?
  is_primary                                    Boolean         @default(false)
  status                                        String          @default("active")
  created_by                                    String?         @db.Uuid
  updated_by                                    String?         @db.Uuid
  created_at                                    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                                    DateTime        @default(now()) @db.Timestamptz(6)
  mobile_numbers                                Json            @default("[]")
  email_addresses                               Json            @default("[]")
  companies                                     companies       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  profiles_contact_persons_created_byToprofiles profiles?       @relation("contact_persons_created_byToprofiles", fields: [created_by], references: [id])
  organizations                                 organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles_contact_persons_updated_byToprofiles profiles?       @relation("contact_persons_updated_byToprofiles", fields: [updated_by], references: [id])
  documents                                     documents[]
  followups                                     followups[]
  help_requests                                 help_requests[]
  interactions                                  interactions[]

  @@index([company_id])
  @@index([organization_id])
}

model document_download_logs {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  document_id     String        @db.Uuid
  downloaded_by   String        @db.Uuid
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  documents       documents     @relation(fields: [document_id], references: [id], onDelete: Cascade)
  profiles        profiles      @relation(fields: [downloaded_by], references: [id], onDelete: Cascade)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

model documents {
  id                                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                          String                   @db.Uuid
  file_size_mb                             Decimal?                 @db.Decimal
  created_at                               DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime?                @default(now()) @db.Timestamptz(6)
  company_id                               String                   @db.Uuid
  contact_person_id                        String?                  @db.Uuid
  interaction_id                           String?                  @db.Uuid
  followup_id                              String?                  @db.Uuid
  document_type                            String                   @default("Other")
  title                                    String
  description                              String?
  file_name                                String
  file_path                                String
  file_url                                 String?
  mime_type                                String?
  file_extension                           String?
  status                                   String?                  @default("submitted")
  submitted_to                             String?
  submitted_at                             DateTime?                @db.Timestamptz(6)
  expiry_date                              DateTime?                @db.Date
  remarks                                  String?
  created_by                               String?                  @db.Uuid
  updated_by                               String?                  @db.Uuid
  uploaded_by                              String?                  @db.Uuid
  document_download_logs                   document_download_logs[]
  companies                                companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contact_persons                          contact_persons?         @relation(fields: [contact_person_id], references: [id])
  profiles_documents_created_byToprofiles  profiles?                @relation("documents_created_byToprofiles", fields: [created_by], references: [id])
  followups                                followups?               @relation(fields: [followup_id], references: [id])
  interactions                             interactions?            @relation(fields: [interaction_id], references: [id])
  organizations                            organizations            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles_documents_updated_byToprofiles  profiles?                @relation("documents_updated_byToprofiles", fields: [updated_by], references: [id])
  profiles_documents_uploaded_byToprofiles profiles?                @relation("documents_uploaded_byToprofiles", fields: [uploaded_by], references: [id])
  help_requests                            help_requests[]

  @@index([organization_id, company_id, created_at(sort: Desc)])
  @@index([organization_id])
  @@index([organization_id, status, created_at(sort: Desc)])
}

model email_reminder_logs {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  followup_id     String        @db.Uuid
  user_id         String        @db.Uuid
  email           String
  status          String        @default("pending")
  provider        String?
  error_message   String?
  sent_at         DateTime?     @db.Timestamptz(6)
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  followups       followups     @relation(fields: [followup_id], references: [id], onDelete: Cascade)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles        profiles      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model followups {
  id                                            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                               String                  @db.Uuid
  company_id                                    String                  @db.Uuid
  contact_person_id                             String?                 @db.Uuid
  interaction_id                                String?                 @db.Uuid
  assigned_user_id                              String?                 @db.Uuid
  followup_type                                 String                  @default("Phone Call")
  title                                         String
  description                                   String?
  scheduled_at                                  DateTime                @db.Timestamptz(6)
  reminder_before_minutes                       Int?                    @default(60)
  status                                        String                  @default("pending")
  priority                                      String                  @default("medium")
  completed_at                                  DateTime?               @db.Timestamptz(6)
  completed_by                                  String?                 @db.Uuid
  rescheduled_from                              DateTime?               @db.Timestamptz(6)
  cancelled_reason                              String?
  created_by                                    String                  @db.Uuid
  updated_by                                    String                  @db.Uuid
  created_at                                    DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at                                    DateTime?               @default(now()) @db.Timestamptz(6)
  documents                                     documents[]
  email_reminder_logs                           email_reminder_logs[]
  profiles_followups_assigned_user_idToprofiles profiles?               @relation("followups_assigned_user_idToprofiles", fields: [assigned_user_id], references: [id])
  companies                                     companies               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  profiles_followups_completed_byToprofiles     profiles?               @relation("followups_completed_byToprofiles", fields: [completed_by], references: [id])
  contact_persons                               contact_persons?        @relation(fields: [contact_person_id], references: [id])
  profiles_followups_created_byToprofiles       profiles                @relation("followups_created_byToprofiles", fields: [created_by], references: [id], onDelete: Cascade)
  interactions                                  interactions?           @relation(fields: [interaction_id], references: [id])
  organizations                                 organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles_followups_updated_byToprofiles       profiles                @relation("followups_updated_byToprofiles", fields: [updated_by], references: [id], onDelete: Cascade)
  help_requests                                 help_requests[]
  scoring_activity_logs                         scoring_activity_logs[]
  wallet_transactions                           wallet_transactions[]
}

model help_request_comments {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  help_request_id String        @db.Uuid
  user_id         String        @db.Uuid
  comment         String
  is_internal     Boolean?      @default(true)
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?     @default(now()) @db.Timestamptz(6)
  help_requests   help_requests @relation(fields: [help_request_id], references: [id], onDelete: Cascade)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles        profiles      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model help_requests {
  id                                            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                               String                  @db.Uuid
  company_id                                    String                  @db.Uuid
  contact_person_id                             String?                 @db.Uuid
  interaction_id                                String?                 @db.Uuid
  followup_id                                   String?                 @db.Uuid
  document_id                                   String?                 @db.Uuid
  requested_by                                  String                  @db.Uuid
  assigned_to                                   String?                 @db.Uuid
  help_type                                     String                  @default("General Support")
  title                                         String
  description                                   String?
  priority                                      String?                 @default("medium")
  status                                        String?                 @default("open")
  resolution_note                               String?
  resolved_at                                   DateTime?               @db.Timestamptz(6)
  resolved_by                                   String?                 @db.Uuid
  created_by                                    String                  @db.Uuid
  updated_by                                    String                  @db.Uuid
  created_at                                    DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at                                    DateTime?               @default(now()) @db.Timestamptz(6)
  help_request_comments                         help_request_comments[]
  profiles_help_requests_assigned_toToprofiles  profiles?               @relation("help_requests_assigned_toToprofiles", fields: [assigned_to], references: [id])
  companies                                     companies               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contact_persons                               contact_persons?        @relation(fields: [contact_person_id], references: [id])
  profiles_help_requests_created_byToprofiles   profiles                @relation("help_requests_created_byToprofiles", fields: [created_by], references: [id], onDelete: Cascade)
  documents                                     documents?              @relation(fields: [document_id], references: [id])
  followups                                     followups?              @relation(fields: [followup_id], references: [id])
  interactions                                  interactions?           @relation(fields: [interaction_id], references: [id])
  organizations                                 organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles_help_requests_requested_byToprofiles profiles                @relation("help_requests_requested_byToprofiles", fields: [requested_by], references: [id], onDelete: Cascade)
  profiles_help_requests_resolved_byToprofiles  profiles?               @relation("help_requests_resolved_byToprofiles", fields: [resolved_by], references: [id])
  profiles_help_requests_updated_byToprofiles   profiles                @relation("help_requests_updated_byToprofiles", fields: [updated_by], references: [id], onDelete: Cascade)
}

model industries {
  id                                       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                          String        @db.Uuid
  name                                     String
  description                              String?
  status                                   String        @default("active")
  created_by                               String?       @db.Uuid
  updated_by                               String?       @db.Uuid
  created_at                               DateTime      @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime      @default(now()) @db.Timestamptz(6)
  companies                                companies[]
  profiles_industries_created_byToprofiles profiles?     @relation("industries_created_byToprofiles", fields: [created_by], references: [id])
  organizations                            organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles_industries_updated_byToprofiles profiles?     @relation("industries_updated_byToprofiles", fields: [updated_by], references: [id])

  @@unique([organization_id, name])
  @@index([organization_id])
}

model interactions {
  id                                               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                                  String           @db.Uuid
  company_id                                       String           @db.Uuid
  contact_person_id                                String?          @db.Uuid
  assigned_user_id                                 String?          @db.Uuid
  interaction_type                                 String           @default("Phone Call")
  meeting_datetime                                 DateTime         @default(now()) @db.Timestamptz(6)
  location                                         String?
  online_meeting_link                              String?
  discussion_details                               String
  client_requirement                               String?
  pain_point                                       String?
  proposed_solution                                String?
  budget_discussion                                String?
  competitor_mentioned                             String?
  decision_timeline                                String?
  success_rating                                   Int?
  lead_temperature                                 String?
  next_action                                      String?
  next_followup_at                                 DateTime?        @db.Timestamptz(6)
  need_help                                        Boolean          @default(false)
  internal_note                                    String?
  status                                           String           @default("active")
  created_by                                       String?          @db.Uuid
  updated_by                                       String?          @db.Uuid
  created_at                                       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                                       DateTime         @default(now()) @db.Timestamptz(6)
  completed_at                                     DateTime?        @db.Timestamptz(6)
  completed_by                                     String?          @db.Uuid
  documents                                        documents[]
  followups                                        followups[]
  help_requests                                    help_requests[]
  profiles_interactions_assigned_user_idToprofiles profiles?        @relation("interactions_assigned_user_idToprofiles", fields: [assigned_user_id], references: [id])
  companies                                        companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  profiles_interactions_completed_byToprofiles     profiles?        @relation("interactions_completed_byToprofiles", fields: [completed_by], references: [id])
  contact_persons                                  contact_persons? @relation(fields: [contact_person_id], references: [id])
  profiles_interactions_created_byToprofiles       profiles?        @relation("interactions_created_byToprofiles", fields: [created_by], references: [id])
  organizations                                    organizations    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles_interactions_updated_byToprofiles       profiles?        @relation("interactions_updated_byToprofiles", fields: [updated_by], references: [id])

  @@index([company_id])
  @@index([completed_at])
  @@index([contact_person_id])
  @@index([meeting_datetime])
  @@index([organization_id])
}

model lead_score_rules {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  action_key      String
  name            String
  description     String?
  points          Int           @default(0)
  is_active       Boolean       @default(true)
  rule_scope      Json          @default("{}")
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, action_key])
}

model lead_source_score_rules {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String        @db.Uuid
  source_name       String
  normalized_source String
  bonus_points      Int           @default(0)
  is_active         Boolean       @default(true)
  rule_scope        Json          @default("{}")
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  updated_at        DateTime      @default(now()) @db.Timestamptz(6)
  organizations     organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, normalized_source])
}

model notifications {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  user_id         String         @db.Uuid
  type            String
  title           String
  message         String
  link            String?
  is_read         Boolean        @default(false)
  read_at         DateTime?      @db.Timestamptz(6)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  scope           String         @default("workspace")
  payload         Json?
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  profiles        profiles       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([organization_id, user_id, created_at(sort: Desc)])
  @@index([organization_id, user_id, is_read, created_at(sort: Desc)])
  @@index([user_id, created_at(sort: Desc)])
  @@index([user_id, scope, is_read, created_at(sort: Desc)])
}

model organizations {
  id                                               String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                             String
  slug                                             String                     @unique
  company_size                                     String?
  owner_user_id                                    String                     @db.Uuid
  created_at                                       DateTime                   @default(now()) @db.Timestamptz(6)
